generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  nombre         String
  estudiantes    Estudiante[]
  gruposAseo     GrupoAseo[]
  representantes Representante[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Estudiante {
  id              String      @id @default(uuid())
  nombre          String
  apellido        String
  fechaNacimiento DateTime
  telefono        String
  acudiente       String
  telefonoAcu     String
  fotoUrl         String?
  usuarioId       String
  usuario         Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  gruposAseo      GrupoAseo[] @relation("EstudiantesGrupoAseo")
  materias        Materia[]         
  mensajes        MensajeEnviado[] 
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([usuarioId])
}

model GrupoAseo {
  id          String       @id @default(uuid())
  dia         DiaSemana
  usuarioId   String
  usuario     Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  estudiantes Estudiante[] @relation("EstudiantesGrupoAseo")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([usuarioId])
  @@unique([usuarioId, dia])
}

model Representante {
  id        String            @id @default(uuid())
  tipo      TipoRepresentante
  nombre    String
  email     String
  telefono  String
  usuarioId String
  usuario   Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([usuarioId])
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
}

enum TipoRepresentante {
  PADRES
  ESTUDIANTES
}

model Materia {
  id            String   @id @default(uuid())
  nombre        String
  estudianteId  String
  estudiante    Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  calificacion  Float
  periodo       String   // Ej: "Primer Periodo", "Segundo Periodo"
  usuarioId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([estudianteId])
  @@index([usuarioId])
}

model MensajeEnviado {
  id            String   @id @default(uuid())
  tipo          TipoMensaje
  mensaje       String
  estudianteId  String
  estudiante    Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  telefono      String
  usuarioId     String
  fechaEnvio    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([estudianteId])
  @@index([usuarioId])
}

enum TipoMensaje {
  FELICITACION
  DISCIPLINA
  CIRCULAR
}